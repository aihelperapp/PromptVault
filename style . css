body{
    margin:0;
    font-family:Arial,sans-serif;
    background:#0f172a;
    color:white;
    text-align:center;
}

header{
    background:#111827;
    padding:20px;
    font-size:28px;
    font-weight:bold;
    color:#38bdf8;
}

.hero{
    padding:80px 20px;
}

.hero h1{
    font-size:45px;
    margin-bottom:10px;
}

.hero p{
    font-size:20px;
    color:#cbd5e1;
}

button{
    margin-top:20px;
    padding:12px 25px;
    border:none;
    border-radius:8px;
    background:#38bdf8;
    color:white;
    font-size:18px;
    cursor:pointer;
}

button:hover{
    background:#0ea5e9;
}